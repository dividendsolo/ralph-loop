#!/bin/bash
# ralph-once — work ONE ticket end to end (board-driven Ralph).
# Picks the next eligible ticket (In Progress mine -> Changes Requested -> Ready
# for Agent) from the repo's board, implements/reworks it, and moves it to "In
# Review". Never merges. Full auto mode: no permission prompts. The box is the sandbox.
set -euo pipefail

# Reachable toolchain even under a minimal (cron) environment.
export PATH="$HOME/.local/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin"

REPO="${RALPH_REPO:-$HOME/code/docket}"

# Full worker procedure lives in the `engineer` skill (installed into ~/.hermes/skills).
# The skill resolves the board/tracker and scope from ~/.claude/afk.json; the
# `cd "$REPO"` below selects which board. Nothing about it is hardcoded here.
PROMPT="Use the engineer skill to pick up and carry EXACTLY ONE ticket forward on this repo's board, then STOP. Follow the skill's procedure in full (resolve the tracker/board and scope from ~/.claude/afk.json, priority order, claim and force-unassign, gitflow branch, LEARNINGS as binding constraints, test-first, stop at the PR). If no ticket is eligible, print <promise>NO_TICKETS</promise> and stop."

# Pull the skills playbook + this repo to current before working.
ralph-sync "$REPO" || true

cd "$REPO"
hermes -z "$PROMPT" --yolo --accept-hooks
