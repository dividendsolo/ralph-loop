#!/bin/bash
# ralph-once — work ONE Linear ticket end to end (board-driven Ralph).
# Picks the next AFK ticket in "Changes Requested" or "Todo" from the Docket
# board, implements/reworks it, and moves it to "In Review". Never merges.
# Full auto mode: no permission prompts. The box itself is the sandbox.
set -euo pipefail

# Reachable toolchain even under a minimal (cron) environment.
export PATH="$HOME/.local/bin:/usr/local/bin:/usr/bin:/bin"

REPO="${RALPH_REPO:-$HOME/code/docket}"

# Full worker procedure lives in the `pickup` skill (installed into ~/.hermes/skills).
PROMPT="Use the pickup skill to pick up and carry exactly ONE ticket forward on the Docket board (Linear project \"Docket phase 1: ingest, feed, reader\", team \"James Gooding\"; repo $REPO), then STOP. Follow the skill's procedure in full. Scope: only issues carrying the \"AFK\" label. If no ticket is eligible, print <promise>NO_TICKETS</promise> and stop."

cd "$REPO"
hermes -z "$PROMPT" --yolo --accept-hooks
