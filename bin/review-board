#!/bin/bash
# review-board — one pass of the Docket PR review loop (senior-reviewer role).
# Runs headless Claude against the procedure in ~/.claude/review-board.md.
# Invoked by cron on a schedule, and runnable by hand any time.
set -euo pipefail

# Cron runs with a minimal environment; make the toolchain reachable.
export PATH="$HOME/.local/bin:/usr/local/bin:/usr/bin:/bin"

PROMPT_FILE="$HOME/.claude/review-board.md"
REPO="$HOME/code/docket"
LOG="$HOME/review-board.log"

cd "$REPO"

{
  echo "===== review-board run $(date -u +'%Y-%m-%dT%H:%M:%SZ') ====="
  claude --dangerously-skip-permissions -p "$(cat "$PROMPT_FILE")"
  echo
} >> "$LOG" 2>&1
