#!/bin/bash
# review-board — cron entrypoint for the REVIEWER Ralph loop (senior-reviewer role).
# Cron fires this on a schedule; it just kicks off `review-ralph`, which invokes the
# `reviewer` skill once per iteration (one "In Review" PR each) until the
# review queue is clear or the iteration budget is reached.
#
# Single-instance lock: a loop pass can outlast the cron interval, so overlapping
# ticks would race (double review / double merge on one PR). flock makes a new
# invocation SKIP if a pass is already running, guarding both cron ticks and manual
# runs. Polling frequently is cheap because reviewer is idempotent per head
# SHA (it skips already-reviewed unchanged PRs) and exits early when nothing is In
# Review (`<promise>NO_PRS</promise>`).
set -euo pipefail

# Cron runs with a minimal environment; make the toolchain reachable.
export PATH="$HOME/.local/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin"

LOG="$HOME/review-board.log"
LOCKFILE="$HOME/.review-board.lock"
# Max PRs to drain per cron tick; review-ralph exits earlier on NO_PRS. Override
# with REVIEW_ITERS in the environment.
ITERS="${REVIEW_ITERS:-5}"

# Acquire the single-instance lock (non-blocking). If held, a pass is already in
# flight — skip quietly rather than pile on and race it.
exec 9>"$LOCKFILE"
if ! flock -n 9; then
  echo "===== review-board skipped: a pass is already running ($(date -u +'%Y-%m-%dT%H:%M:%SZ')) =====" >> "$LOG"
  exit 0
fi

# review-ralph tees its own output to $LOG, so do NOT redirect here (that would
# double-write every line). Its stdout copy goes to cron's (absent) mailer.
#
# Multi-repo: review every repo registered in afk.json (a single-repo default left
# non-docket PRs rotting In Review — see ENG-99). A failed pass on one repo must
# not stop the others.
AFK="$HOME/.claude/afk.json"
for REPO in $(jq -r ".repos | keys[]" "$AFK"); do
  if [ ! -d "$REPO" ]; then
    echo "===== review-board: skipping $REPO (not cloned) ($(date -u +%Y-%m-%dT%H:%M:%SZ)) =====" >> "$LOG"
    continue
  fi
  RALPH_REPO="$REPO" review-ralph "$ITERS" || echo "===== review-board: review-ralph failed for $REPO ($(date -u +%Y-%m-%dT%H:%M:%SZ)) =====" >> "$LOG"
done
