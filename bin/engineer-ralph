#!/bin/bash
# afk-ralph — run the board-driven Ralph loop for up to N iterations.
# Each iteration works ONE ticket (priority: In Progress mine, then Changes
# Requested, then Ready for Agent) from the repo's board. Stops early when the
# board has nothing eligible. The box is the sandbox; no docker.
#
# Resilience (why this is not just `set -e` + a loop): a single non-zero hermes
# exit must NOT kill the whole run. The previous version captured hermes output
# into `result=$(...)` under `set -e`, so any failure aborted the script at that
# line — *before* `echo "$result"` ran — leaving a bare shell prompt and zero
# diagnostics. Now each iteration is retried once, the failure reason is logged,
# and the loop moves on to the next ticket. All output is mirrored to $RALPH_LOG
# so detached/tmux runs stay inspectable after a disconnect.
set -uo pipefail

export HOME="$HOME"
 export PATH="$HOME/.local/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin"

N="${1:-}"
if [ -z "$N" ]; then
  echo "Usage: engineer-ralph <iterations>" >&2
  exit 1
fi

REPO="${RALPH_REPO:-$HOME/code/docket}"
RALPH_LOG="${RALPH_LOG:-$HOME/ralph.log}"
RALPH_LOOP_NAME="work"

# The engineer role is the `engineer` AGENT driving the `engineer` skill. This loop
# still runs it on Hermes (`hermes -z`), which has no custom-agent dispatch, so the
# prompt invokes the skill directly and Hermes IS the engineer. When the worker loop
# moves onto Claude Code (ENG-100), this dispatch becomes `claude --agent engineer`,
# mirroring how review-ralph dispatches `claude --agent reviewer` — and the
# ralph-dispatch helper handles the per-role runner switch transparently.
#
# The full worker procedure lives in the `engineer` skill (in ~/code/skills,
# installed into ~/.hermes/skills). This prompt just invokes it; the skill resolves
# the board/tracker and scope from ~/.claude/afk.json and owns ticket-priority order,
# claim+unassign, gitflow branch, LEARNINGS, TDD, stop-at-PR. Nothing about the
# board is hardcoded here — the `cd "$REPO"` below is what selects it.
PROMPT="Use the engineer skill to pick up and carry EXACTLY ONE ticket forward on this repo's board, then STOP. Follow the skill's procedure in full (resolve the tracker/board and scope from ~/.claude/afk.json, priority order, claim and force-unassign, gitflow branch, LEARNINGS as binding constraints, test-first, stop at the PR). If no ticket is eligible, print <promise>NO_TICKETS</promise> and stop."

# Source the shared dispatch helper. The helper runs the per-role runner (Hermes
# for the engineer today, Claude Code once ENG-100 lands) and falls back to
# Hermes/MiniMax-M3 if the primary refuses with the Anthropic weekly rate limit.
# shellcheck source=ralph-dispatch
. "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/ralph-dispatch"
# Source the heartbeat recorder so we can stamp every iteration's outcome into
# ~/ralph-status.json + ~/ralph-status.html for the dashboard. record_heartbeat
# lives in bin/ralph-status and needs the same env as a sourced call.
# shellcheck source=ralph-status
. "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/ralph-status"

cd "$REPO" || { echo "engineer-ralph: repo not found: $REPO (set RALPH_REPO)" >&2; exit 1; }

# Resolve the per-repo profile wrapper for dispatch. The dispatcher will use
# `hermes-<repo>` when the box has the wrapper on PATH (post-ENG-133 human
# setup) and fall back to bare `hermes` until then. Setting RALPH_REPO_NAME
# here lets ralph-dispatch pick the right command without the legs having
# to know how profiles are wired.
RALPH_REPO_NAME="$(basename "$REPO")"
export RALPH_REPO_NAME

# Mirror banners + hermes output to the persistent log as well as the terminal.
log() { printf '%s\n' "$*" | tee -a "$RALPH_LOG"; }

# Self-heal the rate-limit state file at the start of every new tick. Today the
# engineer's primary is Hermes, so the fallback path is dormant — but once the
# worker moves to Claude Code per ENG-100, the state file will start appearing,
# and this line is what makes the loop self-heal back to the primary when the
# Anthropic limit lifts.
rm -f "$HOME/.${RALPH_LOOP_NAME}-rate-limited"

log "===== engineer-ralph start: $N iteration(s), repo=$REPO, log=$RALPH_LOG ($(TZ=America/New_York date +"%b %d %I:%M:%S %p %Z")) ====="

# Pull the skills playbook + this repo to current before working, so the agent
# never runs a stale engineer skill or branches off a behind main.
ralph-sync "$REPO" 2>&1 | tee -a "$RALPH_LOG" || true

failures=0
for ((i=1; i<=N; i++)); do
  log "===== ralph board iteration $i / $N ($(TZ=America/New_York date +"%I:%M:%S %p %Z")) ====="

  result=""
  rc=0
  for attempt in 1 2 3 4; do
    # Capture stdout+stderr together so any failure is preserved and logged.
    # ralph-dispatch selects Hermes as the engineer primary today; once ENG-100
    # lands, switch the case in ralph-dispatch to `claude --agent engineer` and
    # the rate-limit fallback kicks in automatically.
    dispatch_role engineer "$PROMPT"
    rc=$?
    result="$RALPH_DISPATCH_OUTPUT"

    # Extract ticket from output and write to live status file for dashboard.
    # NOT `local`: this block is at script body, not inside a function, and
    # `local` here silently prints `local: can only be used in a function`
    # (LEARNINGS ENG-182) while still working in global scope.
    ticket_id=$(printf '%s' "$result" | grep -oP 'ENG-\d+' 2>/dev/null | head -1)
    [ -n "$ticket_id" ] && printf '%s\n' "$ticket_id" > "$HOME/.engineer-current-ticket"
    # Success is judged by OUTPUT, not exit code. hermes -z exits non-zero even
    # on a fully successful ticket (git/PR/hook activity during teardown), so the
    # exit code is an unreliable success signal. A genuine startup crash produces
    # EMPTY output — that is the only case worth retrying.
    if [ -n "${result//[[:space:]]/}" ]; then
      break
    fi
    log "----- iteration $i attempt $attempt produced NO output (dispatch exit $rc) — likely a startup crash -----"
    if [ "$attempt" = 1 ]; then
      log "retrying in 15s..."
      sleep 15
    fi
  done

  if [ -z "${result//[[:space:]]/}" ]; then
    log "===== iteration $i: dispatch produced no output after 2 attempts (last exit $rc); skipping. ====="
    # Even on a hard dispatch failure the dashboard must record the tick so the
    # operator sees "something tried and failed" rather than a blank cell. Pass
    # a non-"exit 0" detail so record_heartbeat classifies this as `failed`
    # (per the loop-integration test contract AC 3, "startup crash" is failed
    # regardless of dispatch rc).
    record_heartbeat worker "$(basename "$REPO")" "" "dispatch produced no output after retries (rc=$rc)"
    failures=$((failures + 1))
    continue
  fi

  log "$result"
  # Record the heartbeat for the dashboard BEFORE checking for the NO_TICKETS
  # token, so an iteration that ran a ticket still gets the cell stamped. The
  # recorder reads RALPH_DISPATCH_TIER exported by the dispatcher.
  # Leg is `worker` (matches the loop-integration test contract; `engineer` is
  # the script's CLI name, `worker` is the dashboard-leg label for the same
  # role). See LEARNINGS follow-up card ENG-181 for the original split.
  record_heartbeat worker "$(basename "$REPO")" "$result" "exit $rc"
  if [ "$rc" -ne 0 ]; then
    log "(note: dispatch exit $rc on a ticket that produced output; expected; success judged by output, not exit code.)"
  fi

  if [[ "$result" == *"<promise>NO_TICKETS</promise>"* ]]; then
    log "===== board clear: no eligible tickets after $i iteration(s). ====="
    exit 0
  fi
done

log "===== reached $N iteration(s); more tickets may remain (failures this run: $failures). ====="
