#!/bin/bash
# ralph-sync — bring the agent's dependencies up to date before a loop run.
#
# Pushing to main from the laptop does NOT reach this box on its own. The loop
# runs straight out of the local checkouts, so a stale checkout means the agent
# runs stale code: a stale `skills` playbook (the original dev-ticket bug), or a
# target repo whose main/LEARNINGS.md is behind. This pulls both right before the
# loop, so freshness is tied to the moment of use rather than a side-band cron.
#
# What it pulls:
#   - ~/code/skills        : the agent playbooks (symlinked into ~/.claude/skills)
#   - ~/code/ralph-loop    : the loop's own scripts (symlinked into ~/.local/bin).
#                            The running instance keeps its already-loaded copy;
#                            the pull lands the update for the NEXT tick.
#   - ~/code/dotfiles      : James's global config; ~/.claude/CLAUDE.md is a
#                            symlink into it, so pulling refreshes the agent's
#                            global working rules with no extra step.
#   - $1 (the target repo) : the repo the loop is about to work/review
#
# Auth: the checkouts use HTTPS remotes, so git reuses the gh credential helper
# (the same auth the agents already use to push and open PRs) — no SSH key needed.
#
# Safety: --ff-only never clobbers local work; a repo with uncommitted edits or a
# diverged history is left untouched and logged. Best-effort throughout: a failed
# pull must never block the loop, so every step falls through.
set -uo pipefail

export PATH="$HOME/.local/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin"

sync_one() {
  local repo="$1"
  [ -n "$repo" ] && [ -d "$repo/.git" ] || { echo "ralph-sync: skip (not a git repo): $repo"; return 0; }
  # Workers leave the checkout on their feature branch when an iteration ends;
  # a plain pull then tracks the BRANCH, so main's skill/script updates never
  # land and agents run stale playbooks (found via ENG-171: the reviewer kept
  # Discord-pinging hours after the rule was removed on main). If the tree is
  # clean, return to the default branch first; if dirty, leave the repo
  # untouched — same safety contract as --ff-only below.
  local default branch
  default=$(git -C "$repo" symbolic-ref --short refs/remotes/origin/HEAD 2>/dev/null | sed 's|^origin/||')
  default=${default:-main}
  branch=$(git -C "$repo" branch --show-current 2>/dev/null)
  if [ -n "$branch" ] && [ "$branch" != "$default" ]; then
    if [ -z "$(git -C "$repo" status --porcelain 2>/dev/null)" ]; then
      git -C "$repo" checkout --quiet "$default" 2>/dev/null \
        && echo "ralph-sync: $(basename "$repo") left on $branch by a worker — switched back to $default"
    else
      echo "ralph-sync: $(basename "$repo") on $branch WITH local changes — left untouched"
      return 0
    fi
  fi
  local before after
  before=$(git -C "$repo" rev-parse --short HEAD 2>/dev/null)
  if git -C "$repo" pull --ff-only --quiet 2>/dev/null; then
    after=$(git -C "$repo" rev-parse --short HEAD 2>/dev/null)
    if [ "$before" = "$after" ]; then
      echo "ralph-sync: $(basename "$repo") up to date ($after)"
    else
      echo "ralph-sync: $(basename "$repo") $before -> $after"
    fi
  else
    echo "ralph-sync: $(basename "$repo") NOT fast-forwarded (local changes or diverged) — left untouched"
  fi
}

sync_one "$HOME/code/skills"
sync_one "$HOME/code/ralph-loop"
sync_one "$HOME/code/dotfiles"
sync_one "${1:-}"
