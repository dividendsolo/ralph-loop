#!/bin/bash
# review-ralph — board-driven REVIEWER Ralph loop, up to N iterations.
# Each iteration dispatches the `reviewer` AGENT (`claude --agent reviewer`), the
# review specialist that drives the `reviewer` skill: it reviews EXACTLY ONE
# "In Review" PR and then STOPS (the skill no longer loops itself — the loop lives
# here). The loop drains the review queue one PR per iteration and exits early when
# the agent reports the queue is clear (`<promise>NO_PRS</promise>`).
# The box is the sandbox; no docker.
#
# Runner: `claude -p` (Claude Code headless), chosen over the worker loop's
# `hermes -z`. claude's exit code is meaningful, but we still judge "queue clear"
# by OUTPUT (the NO_PRS token), and treat EMPTY output as a startup crash worth one
# retry — a single bad iteration must not abort the whole run.
#
# The board/tracker is NOT hardcoded here: `reviewer` resolves it from
# ~/.claude/afk.json. If that registry is missing the skill says so and stops, and
# this loop logs each iteration's output so the reason stays inspectable.
set -uo pipefail

# Reachable toolchain even under a minimal (cron) environment.
export HOME="$HOME"
 export PATH="$HOME/.local/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin"

N="${1:-${REVIEW_ITERS:-5}}"

REPO="${RALPH_REPO:-$HOME/code/docket}"
RALPH_LOG="${REVIEW_LOG:-$HOME/review-board.log}"
RALPH_LOOP_NAME="review"

# The full reviewer procedure lives in the `reviewer` skill (in ~/code/skills,
# symlinked into ~/.claude/skills). This prompt just invokes it for one PR; the skill
# owns scope (In Review), idempotency by head SHA, the independent sub-reviewer,
# decide/act, LEARNINGS curation, and the Discord notify.
PROMPT="Use the reviewer skill to review EXACTLY ONE In Review PR on this repo's board, then STOP. Follow the skill's procedure in full (resolve the board/tracker from ~/.claude/afk.json, idempotency by head SHA, independent sub-reviewer, decide and act, curate LEARNINGS, notify). If no PR is eligible, print <promise>NO_PRS</promise> and stop."

# `ralph-dispatch` lives in the same bin/ directory. Cron's PATH already covers
# ~/.local/bin (which symlinks here), but `source` by absolute path so a manual
# run from anywhere picks up the helper too.
# shellcheck source=ralph-dispatch
. "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/ralph-dispatch"
# shellcheck source=ralph-status
. "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/ralph-status"

cd "$REPO" || { echo "review-ralph: repo not found: $REPO (set RALPH_REPO)" >&2; exit 1; }

# Resolve the per-repo profile wrapper for dispatch. The dispatcher will use
# `hermes-<repo>` when the box has the wrapper on PATH (post-ENG-133 human
# setup) and fall back to bare `hermes` until then. Setting RALPH_REPO_NAME
# here lets ralph-dispatch pick the right command without the legs having
# to know how profiles are wired.
RALPH_REPO_NAME="$(basename "$REPO")"
export RALPH_REPO_NAME

# Mirror banners + agent output to the persistent log as well as the terminal.
log() { printf '%s\n' "$*" | tee -a "$RALPH_LOG"; }

# Self-heal the rate-limit state file at the start of every new tick, so the
# moment the Anthropic weekly limit lifts, the next primary attempt uses Claude
# Code again (not the Hermes fallback). ralph-dispatch writes the state file
# when it detects a rate-limit refusal; this is the only place that clears it.
rm -f "$HOME/.${RALPH_LOOP_NAME}-rate-limited"

log "===== review-ralph start: up to $N iteration(s), repo=$REPO, log=$RALPH_LOG ($(TZ=America/New_York date +"%b %d %I:%M:%S %p %Z")) ====="

# Pull the skills playbook + this repo to current before reviewing, so the agent
# never runs a stale reviewer or reviews against a behind main/LEARNINGS.md.
ralph-sync "$REPO" 2>&1 | tee -a "$RALPH_LOG" || true

failures=0
for ((i=1; i<=N; i++)); do
  log "===== reviewer iteration $i / $N ($(TZ=America/New_York date +"%I:%M:%S %p %Z")) ====="

  result=""
  rc=0
  for attempt in 1 2 3 4; do
    # Capture stdout+stderr together so any failure is preserved and logged.
    # ralph-dispatch runs the per-role runner (Claude Code primary, Hermes
    # fallback on rate-limit) and writes its own FALLBACK banners to the log.
    dispatch_role reviewer "$PROMPT"
    rc=$?
    result="$RALPH_DISPATCH_OUTPUT"
    # A successful run always prints something (a per-PR summary, or the NO_PRS
    # token). EMPTY output is the only signal of a genuine startup crash — retry it.
    if [ -n "${result//[[:space:]]/}" ]; then
      break
    fi
    log "----- iteration $i attempt $attempt produced NO output (dispatch exit $rc) — likely a startup crash -----"
    if [ "$attempt" = 1 ]; then
      log "retrying in 15s..."
      sleep 15
    fi
  done

  if [ -z "${result//[[:space:]]/}" ]; then
    log "===== iteration $i: dispatch produced no output after 2 attempts (last exit $rc); skipping. ====="
    failures=$((failures + 1))
    continue
  fi

  log "$result"
  # Record the heartbeat for the dashboard before checking for the NO_PRS
  # token, so an iteration that reviewed a PR still gets the cell stamped.
  record_heartbeat reviewer "$(basename "$REPO")" "$result" "exit $rc"

  if [[ "$result" == *"<promise>NO_PRS</promise>"* ]]; then
    log "===== review queue clear: no eligible PRs after $i iteration(s). ====="
    exit 0
  fi
done

log "===== reached $N iteration(s); more PRs may remain (failures this run: $failures). ====="
